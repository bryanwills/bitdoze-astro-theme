---
import Layout from '@layouts/Layout.astro';
import { siteConfig } from '@config/site';
---

<Layout
  title={"Search - " + siteConfig.title}
  description={"Search for articles and tutorials on " + siteConfig.title}
  noindex={true}
>
  <div class="max-w-4xl mx-auto py-8">
    <h1 class="text-3xl font-bold mb-8 text-center">Search</h1>

    <form id="search-form" class="mb-8" role="search" action="/search/" method="get">
      <label for="search-input" class="sr-only">Search articles</label>
      <div class="relative">
        <input
          type="search"
          id="search-input"
          name="q"
          placeholder="Search for articles..."
          class="w-full px-4 py-3 pr-12 border border-gray-300 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-800 text-gray-900 dark:text-white"
          autocomplete="off"
          enterkeyhint="search"
        />
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" class="absolute right-3 top-3 h-6 w-6 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
    </form>

    <p id="search-info" class="text-center mb-6 text-gray-600 dark:text-gray-300 text-lg" role="status" aria-live="polite"></p>

    <div id="search-results" class="grid grid-cols-1 md:grid-cols-2 gap-6" aria-busy="false"></div>

    <div id="no-results" class="hidden text-center py-8">
      <p class="text-lg text-gray-600 dark:text-gray-300">No results found. Try a different search term.</p>
    </div>
  </div>
</Layout>

<script>
  import Fuse from 'fuse.js';

  interface SearchPost {
    slug: string;
    title: string;
    description: string;
    date: string;
    image: { src: string; width: number; height: number } | null;
    categories: string[];
    tags: string[];
    content: string;
  }

  const MAX_RESULTS = 12;

  function slugify(value = '') {
    return String(value)
      .normalize('NFKD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase()
      .trim()
      .replace(/&/g, ' and ')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
  }

  function createTextElement(tagName: string, text: string, className?: string) {
    const element = document.createElement(tagName);
    element.textContent = text;
    if (className) element.className = className;
    return element;
  }

  function createResultCard(post: SearchPost) {
    const article = document.createElement('article');
    article.className = 'bg-white dark:bg-gray-800 rounded-lg overflow-hidden shadow-md hover:shadow-lg transition-shadow duration-300';
    const postUrl = import.meta.env.BASE_URL + post.slug + '/';

    if (post.image?.src) {
      const imageLink = document.createElement('a');
      imageLink.href = postUrl;
      imageLink.className = 'block aspect-video overflow-hidden';

      const image = document.createElement('img');
      image.src = post.image.src.startsWith('/') ? post.image.src : '/' + post.image.src;
      image.alt = post.title;
      image.className = 'w-full h-full object-cover hover:scale-105 transition-transform duration-300';
      image.width = post.image.width || 400;
      image.height = post.image.height || 225;
      image.loading = 'lazy';
      image.decoding = 'async';
      imageLink.appendChild(image);
      article.appendChild(imageLink);
    }

    const content = document.createElement('div');
    content.className = 'p-4';

    const meta = document.createElement('div');
    meta.className = 'flex flex-wrap items-center gap-3 text-xs text-gray-500 dark:text-gray-400 mb-3';
    if (post.date) {
      const time = document.createElement('time');
      time.textContent = post.date;
      meta.appendChild(time);
    }
    if (post.categories.length) {
      meta.appendChild(createTextElement('span', post.categories.join(', ')));
    }

    const heading = document.createElement('h2');
    heading.className = 'text-lg font-semibold text-gray-900 dark:text-white mb-2 line-clamp-2';
    const titleLink = document.createElement('a');
    titleLink.href = postUrl;
    titleLink.className = 'hover:text-blue-600 dark:hover:text-blue-400 transition-colors';
    titleLink.textContent = post.title;
    heading.appendChild(titleLink);

    content.append(meta, heading);
    if (post.description) {
      content.appendChild(createTextElement(
        'p',
        post.description,
        'text-sm text-gray-600 dark:text-gray-300 mb-3 line-clamp-2',
      ));
    }

    if (post.tags.length) {
      const tags = document.createElement('div');
      tags.className = 'flex flex-wrap gap-2 mt-3';
      post.tags.slice(0, 3).forEach((tag) => {
        const link = document.createElement('a');
        link.href = import.meta.env.BASE_URL + 'tags/' + slugify(tag) + '/';
        link.className = 'px-2 py-1 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-full text-xs hover:bg-blue-100 dark:hover:bg-blue-900 transition-colors';
        link.textContent = '#' + tag;
        tags.appendChild(link);
      });
      content.appendChild(tags);
    }

    article.appendChild(content);
    return article;
  }

  async function initSearch() {
    const form = document.querySelector<HTMLFormElement>('#search-form');
    const searchInput = document.querySelector<HTMLInputElement>('#search-input');
    const searchResults = document.querySelector<HTMLElement>('#search-results');
    const noResults = document.querySelector<HTMLElement>('#no-results');
    const searchInfo = document.querySelector<HTMLElement>('#search-info');
    if (!form || !searchInput || !searchResults || !noResults || !searchInfo) return;

    let fuse: Fuse<SearchPost> | null = null;
    let debounceTimer: number | undefined;

    const loadIndex = async () => {
      if (fuse) return fuse;
      searchResults.setAttribute('aria-busy', 'true');
      searchInfo.textContent = 'Loading search index…';

      const response = await fetch(import.meta.env.BASE_URL + 'search.json');
      if (!response.ok) throw new Error('Failed to fetch search data');
      const searchData = await response.json() as SearchPost[];
      fuse = new Fuse(searchData, {
        keys: [
          { name: 'title', weight: 0.4 },
          { name: 'tags', weight: 0.2 },
          { name: 'categories', weight: 0.15 },
          { name: 'description', weight: 0.15 },
          { name: 'content', weight: 0.1 },
        ],
        minMatchCharLength: 2,
        ignoreLocation: true,
        threshold: 0.32,
      });
      searchResults.setAttribute('aria-busy', 'false');
      searchInfo.textContent = '';
      return fuse;
    };

    const performSearch = async (rawQuery: string) => {
      const query = rawQuery.trim();
      const url = new URL(window.location.href);
      if (query) url.searchParams.set('q', query);
      else url.searchParams.delete('q');
      history.replaceState(null, '', url);

      searchResults.replaceChildren();
      noResults.classList.add('hidden');
      if (!query) {
        searchInfo.textContent = '';
        return;
      }

      try {
        const index = await loadIndex();
        const results = index.search(query).slice(0, MAX_RESULTS);
        results.forEach((result) => searchResults.appendChild(createResultCard(result.item)));
        noResults.classList.toggle('hidden', results.length !== 0);
        searchInfo.textContent = results.length
          ? 'Found ' + results.length + ' result' + (results.length === 1 ? '' : 's') + ' for “' + query + '”'
          : 'No results found for “' + query + '”';
      } catch (error) {
        console.error('Error loading search data:', error);
        searchResults.setAttribute('aria-busy', 'false');
        searchInfo.textContent = 'Search is unavailable right now. Please try again later.';
      }
    };

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      void performSearch(searchInput.value);
    });

    searchInput.addEventListener('input', () => {
      window.clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => void performSearch(searchInput.value), 250);
    });

    const initialQuery = new URLSearchParams(window.location.search).get('q') || '';
    searchInput.value = initialQuery;
    if (initialQuery) await performSearch(initialQuery);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => void initSearch(), { once: true });
  } else {
    void initSearch();
  }
</script>
