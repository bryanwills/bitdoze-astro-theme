<div class="tabs-container">
  <div class="tab-list flex flex-wrap border-b border-gray-200 dark:border-gray-700" role="tablist"></div>
  <div class="tab-panels mt-4">
    <slot />
  </div>
</div>

<style>
  .tabs-container :global(.tab-panel[hidden]) {
    display: none;
  }

  .tabs-container:not([data-tabs-ready]) .tab-panels > :global(.tab-panel:not(:first-child)) {
    display: none;
  }
</style>

<script>
  const activeTabClasses = 'tab-btn px-4 py-2 text-sm font-medium transition-colors border-b-2 border-blue-600 text-blue-600';
  const inactiveTabClasses = 'tab-btn px-4 py-2 text-sm font-medium transition-colors text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200';

  function activateTab(
    tabs: HTMLButtonElement[],
    panels: HTMLElement[],
    activeIndex: number,
    moveFocus = false,
  ) {
    tabs.forEach((tab, index) => {
      const isActive = index === activeIndex;
      tab.className = isActive ? activeTabClasses : inactiveTabClasses;
      tab.setAttribute('aria-selected', String(isActive));
      tab.tabIndex = isActive ? 0 : -1;
      panels[index].hidden = !isActive;
    });

    if (moveFocus) tabs[activeIndex].focus();
  }

  function initTabs() {
    document.querySelectorAll<HTMLElement>('.tabs-container').forEach((container, containerIndex) => {
      if (container.dataset.tabsReady === 'true') return;

      const tabList = container.querySelector('.tab-list');
      const panels = Array.from(container.querySelectorAll<HTMLElement>('.tab-panel'));
      if (!tabList || !panels.length) return;

      tabList.replaceChildren();
      const tabs: HTMLButtonElement[] = [];

      panels.forEach((panel, index) => {
        const name = panel.getAttribute('data-name') || 'Tab ' + (index + 1);
        const tabId = 'tabs-' + containerIndex + '-tab-' + index;
        const panelId = 'tabs-' + containerIndex + '-panel-' + index;
        const button = document.createElement('button');

        button.type = 'button';
        button.className = index === 0 ? activeTabClasses : inactiveTabClasses;
        button.setAttribute('role', 'tab');
        button.setAttribute('aria-selected', String(index === 0));
        button.setAttribute('aria-controls', panelId);
        button.id = tabId;
        button.tabIndex = index === 0 ? 0 : -1;
        button.textContent = name;

        panel.id = panelId;
        panel.setAttribute('role', 'tabpanel');
        panel.setAttribute('aria-labelledby', tabId);
        panel.tabIndex = 0;
        panel.hidden = index !== 0;

        button.addEventListener('click', () => activateTab(tabs, panels, index));
        button.addEventListener('keydown', (event) => {
          let nextIndex: number | null = null;
          if (event.key === 'ArrowRight') nextIndex = (index + 1) % tabs.length;
          if (event.key === 'ArrowLeft') nextIndex = (index - 1 + tabs.length) % tabs.length;
          if (event.key === 'Home') nextIndex = 0;
          if (event.key === 'End') nextIndex = tabs.length - 1;
          if (nextIndex === null) return;
          event.preventDefault();
          activateTab(tabs, panels, nextIndex, true);
        });

        tabs.push(button);
        tabList.appendChild(button);
      });

      container.dataset.tabsReady = 'true';
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTabs, { once: true });
  } else {
    initTabs();
  }

  document.addEventListener('astro:after-swap', initTabs);
</script>
