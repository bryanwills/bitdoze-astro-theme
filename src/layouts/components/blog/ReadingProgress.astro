<div class="reading-progress-container fixed top-0 left-0 w-full h-1 z-60 bg-transparent" aria-hidden="true">
  <div id="reading-progress-bar" class="h-full bg-blue-500 dark:bg-blue-400"></div>
</div>

<script>
  const progressBar = document.querySelector<HTMLElement>('#reading-progress-bar');
  const article = document.querySelector<HTMLElement>('article');

  if (progressBar && article) {
    let articleTop = 0;
    let scrollableArticleHeight = 1;
    let ticking = false;

    const measure = () => {
      articleTop = article.getBoundingClientRect().top + window.scrollY;
      scrollableArticleHeight = Math.max(1, article.offsetHeight - window.innerHeight);
    };

    const updateProgress = () => {
      const progress = Math.min(1, Math.max(0, (window.scrollY - articleTop) / scrollableArticleHeight));
      progressBar.style.transform = 'scaleX(' + progress + ')';
      ticking = false;
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateProgress);
    };

    measure();
    updateProgress();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', () => {
      measure();
      requestUpdate();
    }, { passive: true });
  }
</script>

<style>
  #reading-progress-bar {
    transform: scaleX(0);
    transform-origin: left center;
    will-change: transform;
  }

  .reading-progress-container {
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }
</style>
